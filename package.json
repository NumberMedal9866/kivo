{
  "name": "kiyo-website",
  "version": "0.1.0",
  "private": true,
  "description": "Marketing website for kiyo — self-service ordering kiosks for restaurants and cafés in Uzbekistan.",
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "google-auth-library": "^10.9.0",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "next-intl": "^4.13.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.2.10",
    "prettier": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  }
}
