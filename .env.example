# ---------------------------------------------------------------------------
# KIVO website — environment variables
# Copy this file to .env.local and fill in real values.
# NEVER commit real credentials.
# ---------------------------------------------------------------------------

# Public site URL (no trailing slash). Used for canonical URLs, sitemap, OG.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Lead storage: Google Sheets (server-only, see docs/GOOGLE_SHEETS_SETUP.md)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the full private key. Keep the \n escapes if the value is single-line.
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Leads

# Force the lead API into mock mode (logs to server console, no Google call).
# Mock mode is automatic in development when Google credentials are missing.
LEADS_MOCK_MODE=

# --- Analytics (each is loaded ONLY when its ID is present)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_YANDEX_METRICA_ID=

# --- Contact channels (a channel is rendered ONLY when its value is present)
NEXT_PUBLIC_TELEGRAM_URL=
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_EMAIL=
